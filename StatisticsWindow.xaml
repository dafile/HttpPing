<Window x:Class="HttpPing.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HttpPing"
        Title="统计详情" Width="420" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="White"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Probe Name -->
        <TextBlock Grid.Row="0" x:Name="ProbeNameText" FontSize="16" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,16"/>

        <!-- General Stats -->
        <TextBlock Grid.Row="1" Text="常规统计" FontSize="13" FontWeight="Bold" Foreground="#CCC" Margin="0,0,0,8"/>
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#888" Margin="0,2">
                <Run Text="总检测次数: "/>
                <Run x:Name="TotalChecksText" Foreground="White" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Grid.Row="0" Grid.Column="1" Foreground="#888" Margin="0,2">
                <Run Text="成功率: "/>
                <Run x:Name="UptimeText" Foreground="#4CAF50" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#888" Margin="0,2">
                <Run Text="成功次数: "/>
                <Run x:Name="SuccessCountText" Foreground="#4CAF50" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#888" Margin="0,2">
                <Run Text="失败次数: "/>
                <Run x:Name="FailureCountText" Foreground="#F44336" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Foreground="#888" Margin="0,2">
                <Run Text="最后失败时间: "/>
                <Run x:Name="LastFailureText" Foreground="#FF9800" FontWeight="Bold"/>
            </TextBlock>
        </Grid>

        <!-- Response Time Stats -->
        <TextBlock Grid.Row="3" Text="响应时间" FontSize="13" FontWeight="Bold" Foreground="#CCC" Margin="0,0,0,8"/>
        <Grid Grid.Row="4" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#888" Margin="0,2">
                <Run Text="最小: "/>
                <Run x:Name="MinResponseText" Foreground="White" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Grid.Row="0" Grid.Column="1" Foreground="#888" Margin="0,2">
                <Run Text="最大: "/>
                <Run x:Name="MaxResponseText" Foreground="White" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#888" Margin="0,2">
                <Run Text="平均: "/>
                <Run x:Name="AvgResponseText" Foreground="White" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#888" Margin="0,2">
                <Run Text="最后: "/>
                <Run x:Name="LastResponseText" Foreground="White" FontWeight="Bold"/>
            </TextBlock>
        </Grid>

        <!-- History Count -->
        <TextBlock Grid.Row="5" Foreground="#666" FontSize="11" Margin="0,0,0,8">
            <Run Text="历史记录数: "/>
            <Run x:Name="HistoryCountText"/>
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" Width="70" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
