<UserControl x:Class="HttpPing.Controls.ProbeTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HttpPing.Controls"
             xmlns:converters="clr-namespace:HttpPing.Converters"
             Background="#2D2D2D"
             Margin="3">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </UserControl.Resources>

    <UserControl.ContextMenu>
        <ContextMenu Background="#2D2D2D" Foreground="White">
            <MenuItem Header="开始/停止" Command="{Binding ToggleCommand}"/>
            <MenuItem Header="查看统计" Command="{Binding ShowStatisticsCommand}"/>
            <Separator/>
            <MenuItem Header="复制网址" Command="{Binding CopyUrlCommand}"/>
            <MenuItem Header="在浏览器中打开" Command="{Binding OpenInBrowserCommand}"/>
            <Separator/>
            <MenuItem Header="移除" Command="{Binding RemoveCommand}"/>
        </ContextMenu>
    </UserControl.ContextMenu>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4"/>
        </Grid.RowDefinitions>

        <!-- Title Bar (hover to show) -->
        <Grid Grid.Row="0" x:Name="TitleBar" Background="#1A1A1A" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="▶" FontSize="10" Padding="6,2" Background="Transparent"
                        Foreground="#4CAF50" Command="{Binding ToggleCommand}" ToolTip="开始/停止"
                        Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVis}}"/>
                <Button Content="⏸" FontSize="10" Padding="6,2" Background="Transparent"
                        Foreground="#FF9800" Command="{Binding ToggleCommand}" ToolTip="停止"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                <Button Content="✕" FontSize="10" Padding="6,2" Background="Transparent"
                        Foreground="#999" Command="{Binding RemoveCommand}" ToolTip="移除"/>
            </StackPanel>
        </Grid>

        <!-- Probe Content -->
        <Grid Grid.Row="1" Margin="8,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: URL / Alias -->
            <TextBlock Grid.Row="0" Text="{Binding DisplayName}" Foreground="White"
                       FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,2"
                       ToolTip="{Binding StatusToolTip}"/>

            <!-- Row 1: Status Code + Response Time + Last Check -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,2">
                <TextBlock Text="[" Foreground="#888" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusCode}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="]" Foreground="#888" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="{Binding ResponseTime}" Foreground="#888" FontSize="11" Margin="8,4,0,0"/>
                <TextBlock Text="{Binding LastCheckTime}" Foreground="#666" FontSize="10" Margin="6,4,0,0"/>
            </StackPanel>

            <!-- Row 2: Status Dots (recent results) -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding RecentResults}" Margin="0,2,0,2">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="7" Height="7" Margin="1,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="False">
                                            <Setter Property="Fill" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Row 3: Sparkline -->
            <local:SparklineControl Grid.Row="3"
                ItemsSource="{Binding ResponseTimeHistory}"
                StrokeBrush="#4CAF50"
                FillBrush="#304CAF50"
                Margin="0,2,0,0"/>

            <!-- Row 4: Statistics Summary -->
            <TextBlock Grid.Row="4" Text="{Binding StatsSummary}" Foreground="#888"
                       FontSize="9" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
        </Grid>

        <!-- Color Bar -->
        <Rectangle Grid.Row="2" Fill="{Binding StatusColor}"/>
    </Grid>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard>
                <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TitleBar" Storyboard.TargetProperty="Visibility">
                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                    </ObjectAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard>
                <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TitleBar" Storyboard.TargetProperty="Visibility">
                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
                    </ObjectAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
