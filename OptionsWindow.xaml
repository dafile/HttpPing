<Window x:Class="HttpPing.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选项" Width="420" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="White"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="常规设置" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="检测间隔 (秒):" Width="120" VerticalAlignment="Center"/>
            <TextBox x:Name="IntervalBox" Width="60" Padding="4"
                     Background="#333" Foreground="White" BorderBrush="#555" Text="5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="超时时间 (秒):" Width="120" VerticalAlignment="Center"/>
            <TextBox x:Name="TimeoutBox" Width="60" Padding="4"
                     Background="#333" Foreground="White" BorderBrush="#555" Text="10"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="列数:" Width="120" VerticalAlignment="Center"/>
            <TextBox x:Name="ColumnBox" Width="60" Padding="4"
                     Background="#333" Foreground="White" BorderBrush="#555" Text="3"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="通知设置" FontSize="14" FontWeight="Bold" Margin="0,12,0,8"/>

        <CheckBox Grid.Row="5" x:Name="BalloonCheck" Content="状态变化时显示气泡通知 (系统托盘)"
                  Foreground="White" Margin="0,0,0,4" IsChecked="True"/>
        <CheckBox Grid.Row="6" x:Name="PopupCheck" Content="状态变化时弹出对话框通知"
                  Foreground="White" Margin="0,0,0,4"/>
        <CheckBox Grid.Row="7" x:Name="SoundCheck" Content="状态变化时播放声音"
                  Foreground="White" Margin="0,0,0,4"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="0,4,0,8">
            <TextBlock Text="通知自动消除:" Width="120" VerticalAlignment="Center"/>
            <ComboBox x:Name="DismissCombo" Width="120" Background="#333" Foreground="White"
                      BorderBrush="#555" Padding="4">
                <ComboBoxItem Content="1 分钟" Tag="60"/>
                <ComboBoxItem Content="3 分钟" Tag="180"/>
                <ComboBoxItem Content="5 分钟" Tag="300"/>
                <ComboBoxItem Content="30 分钟" Tag="1800"/>
                <ComboBoxItem Content="1 小时" Tag="3600"/>
                <ComboBoxItem Content="3 小时" Tag="10800"/>
                <ComboBoxItem Content="永不消除" Tag="-1"/>
            </ComboBox>
        </StackPanel>

        <TextBlock Grid.Row="9" Text="窗口设置" FontSize="14" FontWeight="Bold" Margin="0,12,0,8"/>

        <CheckBox Grid.Row="10" x:Name="MinimizeToTrayCheck" Content="关闭窗口时最小化到系统托盘"
                  Foreground="White" Margin="0,0,0,4"/>

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" Width="70" Margin="0,0,8,0" Click="Save_Click"
                    Background="#4CAF50"/>
            <Button Content="取消" Width="70" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
