<Window x:Class="HttpPing.StatusHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="状态历史" Width="700" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="White">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- History DataGrid -->
        <DataGrid Grid.Row="0" x:Name="HistoryGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#2D2D2D"
                  Foreground="White"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#3A3A3A"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#333"/>
                    <Setter Property="Foreground" Value="#CCC"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#444"/>
                    <Setter Property="FontSize" Value="12"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间戳" Binding="{Binding Timestamp, StringFormat=yyyy/MM/dd HH:mm:ss}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCC"/>
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="地址" Binding="{Binding Url}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#4CAF50"/>
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="别名" Binding="{Binding Alias}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#888"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Microsoft YaHei"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ChangeType}" Value="Started">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ChangeType}" Value="Up">
                                    <Setter Property="Foreground" Value="#FF9800"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ChangeType}" Value="Stopped">
                                    <Setter Property="Foreground" Value="#FF9800"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ChangeType}" Value="Down">
                                    <Setter Property="Foreground" Value="#F44336"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom Bar: Filter -->
        <Border Grid.Row="1" Background="#2D2D2D" Padding="8,6" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="过滤器" Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1" x:Name="FilterBox" Background="#333" Foreground="White"
                         BorderBrush="#555" Padding="4,2" VerticalAlignment="Center"
                         TextChanged="FilterBox_TextChanged"/>

                <TextBlock Grid.Column="2" Text="包括" Foreground="#FF9800" VerticalAlignment="Center" Margin="12,0,6,0"/>
                <CheckBox Grid.Column="3" x:Name="ShowUpCheck" Content="恢复连接" Foreground="#4CAF50"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,0"
                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox Grid.Column="4" x:Name="ShowDownCheck" Content="连接断开" Foreground="#F44336"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,0"
                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox Grid.Column="5" x:Name="ShowStartStopCheck" Content="开始/停止" Foreground="#FF9800"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,0"
                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
