<Window x:Class="HttpPing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HttpPing"
        Title="HttpPing v2026.6.6.2330 - HTTP 响应监控" Width="900" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#2D2D2D" Padding="4,2">
            <MenuItem Header="添加主机" Click="AddHost_Click" Foreground="White">
                <MenuItem.Icon>
                    <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" Margin="4,0"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator Background="#444" Width="1" Margin="4,4"/>
            <MenuItem Header="全部开始" Click="StartAll_Click" Foreground="White"/>
            <MenuItem Header="全部停止" Click="StopAll_Click" Foreground="White"/>
            <Separator Background="#444" Width="1" Margin="4,4"/>
            <MenuItem Header="收藏夹" Foreground="White">
                <MenuItem Header="保存当前为收藏" Click="SaveFavorite_Click"/>
                <Separator/>
                <MenuItem x:Name="FavoritesMenu" Header="加载收藏"/>
            </MenuItem>
            <Separator Background="#444" Width="1" Margin="4,4"/>
            <MenuItem Header="状态历史" Click="ShowHistory_Click" Foreground="White"/>
            <Separator Background="#444" Width="1" Margin="4,4"/>
            <MenuItem Header="选项" Click="Options_Click" Foreground="White"/>
        </Menu>

        <!-- Probe Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      x:Name="ProbeScroller">
            <Grid x:Name="ProbeGrid" Margin="4"/>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#1A1A1A" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="#888" FontSize="11">
                    <Run Text="主机: "/>
                    <Run x:Name="TotalProbesText" FontWeight="Bold" Foreground="White" Text="0"/>
                </TextBlock>
                <TextBlock Foreground="#444" Text=" | " Margin="8,0"/>
                <TextBlock Foreground="#888" FontSize="11">
                    <Run Text="正常: "/>
                    <Run x:Name="UpCountText" FontWeight="Bold" Foreground="#4CAF50" Text="0"/>
                </TextBlock>
                <TextBlock Foreground="#444" Text=" | " Margin="8,0"/>
                <TextBlock Foreground="#888" FontSize="11">
                    <Run Text="异常: "/>
                    <Run x:Name="DownCountText" FontWeight="Bold" Foreground="#F44336" Text="0"/>
                </TextBlock>
                <TextBlock Foreground="#444" Text=" | " Margin="8,0"/>
                <TextBlock Foreground="#888" FontSize="11">
                    <Run Text="平均响应: "/>
                    <Run x:Name="AvgResponseText" FontWeight="Bold" Foreground="White" Text="-"/>
                </TextBlock>
                <TextBlock Foreground="#444" Text=" | " Margin="8,0"/>
                <TextBlock Foreground="#888" FontSize="11">
                    <Run Text="可用率: "/>
                    <Run x:Name="GlobalUptimeText" FontWeight="Bold" Foreground="#4CAF50" Text="-"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
